<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.hms.frontend.controller.HospitalController">

    <!-- =====================================================
         TOP SECTION : TITLE
         ===================================================== -->
    <top>
        <Label text="Hospital Management System"
               style="-fx-font-size: 24px;
                      -fx-font-weight: bold;
                      -fx-padding: 15px;" />
    </top>

    <!-- =====================================================
         LEFT SECTION : INPUT FORM
         ===================================================== -->
    <left>
        <VBox spacing="15" prefWidth="320">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <!-- Form Title -->
            <Label text="Patient Details"
                   style="-fx-font-size: 18px;
                          -fx-font-weight: bold;" />

            <!-- Input Fields -->
            <GridPane hgap="10" vgap="10">

                <Label text="Patient ID:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <TextField fx:id="txtPatientId"
                           promptText="Enter Patient ID"
                           GridPane.rowIndex="0"
                           GridPane.columnIndex="1"/>

                <Label text="Patient Name:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <TextField fx:id="txtPatientName"
                           promptText="Enter Patient Name"
                           GridPane.rowIndex="1"
                           GridPane.columnIndex="1"/>

                <Label text="No. of Days:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <TextField fx:id="txtNoOfDays"
                           promptText="Enter Number of Days"
                           GridPane.rowIndex="2"
                           GridPane.columnIndex="1"/>

                <Label text="Bed No:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                <TextField fx:id="txtBedNo"
                           promptText="Enter Bed Number"
                           GridPane.rowIndex="3"
                           GridPane.columnIndex="1"/>

                <Label text="Room No:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                <TextField fx:id="txtRoomNo"
                           promptText="Enter Room Number"
                           GridPane.rowIndex="4"
                           GridPane.columnIndex="1"/>

                <Label text="Floor No:" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                <TextField fx:id="txtFloorNo"
                           promptText="Enter Floor Number"
                           GridPane.rowIndex="5"
                           GridPane.columnIndex="1"/>
            </GridPane>

            <!-- Add Patient Button -->
            <Button text="Add Patient"
                    maxWidth="Infinity"
                    onAction="#addPatient"
                    style="-fx-font-size: 14px;
                           -fx-font-weight: bold;" />

            <!-- Search Section -->
            <Label text="Search / Manage Patient"
                   style="-fx-font-size: 16px;
                          -fx-font-weight: bold;" />

            <TextField fx:id="txtSearchId"
                       promptText="Enter Patient ID" />

            <!-- Action Buttons -->
            <VBox spacing="10">
                <Button text="Search Patient"
                        maxWidth="Infinity"
                        onAction="#searchPatient"/>

                <Button text="Remove Patient"
                        maxWidth="Infinity"
                        onAction="#removePatient"/>

                <Button text="Vacate Bed"
                        maxWidth="Infinity"
                        onAction="#vacateBed"/>

                <Button text="Refresh Table"
                        maxWidth="Infinity"
                        onAction="#displayAllPatients"/>
                <Button text="Update Patient"
                        maxWidth="Infinity"
                        onAction="#updatePatient"/>
            </VBox>
        </VBox>
    </left>

    <!-- =====================================================
         CENTER SECTION : TABLE VIEW
         ===================================================== -->
    <center>
        <VBox spacing="10">
            <padding>
                <Insets top="20" right="20" bottom="20" left="0"/>
            </padding>

            <Label text="Patient Records"
                   style="-fx-font-size: 18px;
                          -fx-font-weight: bold;" />

            <TableView fx:id="tablePatients" prefHeight="500">

                <columns>
                    <TableColumn fx:id="colPatientId"
                                 text="Patient ID"
                                 prefWidth="90"/>

                    <TableColumn fx:id="colPatientName"
                                 text="Patient Name"
                                 prefWidth="150"/>

                    <TableColumn fx:id="colNoOfDays"
                                 text="Days"
                                 prefWidth="70"/>

                    <TableColumn fx:id="colBedNo"
                                 text="Bed No"
                                 prefWidth="70"/>

                    <TableColumn fx:id="colRoomNo"
                                 text="Room No"
                                 prefWidth="80"/>

                    <TableColumn fx:id="colFloorNo"
                                 text="Floor No"
                                 prefWidth="80"/>

                    <TableColumn fx:id="colFee"
                                 text="Total Fee"
                                 prefWidth="100"/>
                </columns>
            </TableView>
        </VBox>
    </center>

</BorderPane>